# OpenWeatherMap API — get a free key at openweathermap.org
# Without this key, the app uses realistic mock weather data
VITE_OPENWEATHER_KEY=fb0a84cc155d4e887a75225ed1c43542

# ─── Power Automate HTTP Trigger URLs ────────────────────────────────────────
# For each: Power Automate → New Flow → Trigger: "When an HTTP request is received"
# Copy the generated POST URL and paste it here.
# Without these, app works normally — data just stays local.
VITE_PA_CLOCK_IN_URL=https://prod-xx.westus.logic.azure.com/workflows/...
VITE_PA_CLOCK_OUT_URL=https://prod-xx.westus.logic.azure.com/workflows/...
VITE_PA_PHOTO_URL=https://prod-xx.westus.logic.azure.com/workflows/...
VITE_PA_ALERT_URL=https://prod-xx.westus.logic.azure.com/workflows/...
VITE_PA_BREAK_URL=https://prod-xx.westus.logic.azure.com/workflows/...

# ─── Microsoft Authentication (MSAL) ──────────────────────────────────────
# Required for Microsoft login and Dataverse access
# 1. Go to portal.azure.com → Azure Active Directory → App registrations → New
# 2. Name: "Richco Construction App"
# 3. Redirect URI: http://localhost:5173 (add https://yourdomain.com for production)
# 4. Copy Application (client) ID → VITE_AZURE_CLIENT_ID
# 5. Copy Directory (tenant) ID → VITE_AZURE_TENANT_ID
VITE_AZURE_CLIENT_ID=e9b090d5-e7a1-43c2-abe3-761a64c828f9
VITE_AZURE_TENANT_ID=59114aa8-a5cf-4ff9-9edd-affc40d640a9

# ─── Dataverse Environment ─────────────────────────────────────────────────
# Your Dataverse organization name (not full URL, just the org part)
# Example: If your URL is https://myorg.crm.dynamics.com, use: myorg
VITE_DATAVERSE_ORG=richcogroup

# Azure OpenAI — for real AI chat (requires Azure OpenAI resource)
VITE_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
VITE_AZURE_OPENAI_KEY=your_azure_openai_key
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4o
